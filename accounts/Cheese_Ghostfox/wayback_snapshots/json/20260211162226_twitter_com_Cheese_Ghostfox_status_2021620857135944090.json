      {
        "article": {},
        "attachments": {},
        "author_id": "894382598004199425",
        "conversation_id": "2021398550576279707",
        "created_at": "2026-02-11T01:39:04.000Z",
        "edit_controls": {
          "editable_until": "2026-02-11T02:39:04.000Z",
